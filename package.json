{
  "name": "echodeck-macos",
  "version": "0.1.0",
  "description": "EchoDeck local-first macOS music player with local playback, playlists, EQ, visualizers, and source-aware streaming embeds.",
  "main": "src/main.js",
  "author": "EchoDeck",
  "license": "MIT",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "package:mac": "electron-builder --mac dmg zip",
    "package:dir": "electron-builder --dir",
    "lint:smoke": "node scripts/smoke-test.js"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.echofoxx.echodeck",
    "productName": "EchoDeck",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json",
      "README.md",
      "docs/**/*"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "EchoDeck-${version}-macOS.${ext}"
    },
    "zip": {
      "artifactName": "EchoDeck-${version}-macOS.${ext}"
    }
  },
  "allowScripts": {
    "electron@31.7.7": true
  }
}
